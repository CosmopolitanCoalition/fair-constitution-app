APP_NAME="Fair Constitution"
APP_ENV=local
# Pre-baked dev key so a fresh `cp .env.example .env && docker compose up -d`
# works without a separate `php artisan key:generate` step. This key is for
# local development only — production deployments MUST regenerate via
# `php artisan key:generate --force` before going public, otherwise sessions
# and signed URLs are forgeable by anyone with a copy of the repo.
APP_KEY=base64:OtMjb7L/Qa9gR8mlUH7yweAD+rokqP/z5FFA9cbl7hU=
APP_DEBUG=true
APP_URL=http://localhost:8080

# ─── Docker multi-stack config ───────────────────────────────
# These four variables let multiple checkouts (parent + N worktrees) run
# their docker stacks simultaneously without colliding on container names
# or host ports. Defaults below match the parent's canonical setup; copy
# this file to .env in each worktree and bump the values.
#
# Worktree example (run alongside the parent):
#   CONTAINER_PREFIX=fcw
#   NGINX_HOST_PORT=8081
#   POSTGRES_HOST_PORT=5433
#   VITE_HOST_PORT=5174
# CONTAINER_PREFIX=fc
# NGINX_HOST_PORT=8080
# POSTGRES_HOST_PORT=5432
# VITE_HOST_PORT=5173

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Geospatial archive path ─────────────────────────────────
# Where the geoBoundaries + WorldPop archive lives on the host. Bind-mounted
# into the etl container at /archive (read-only). Defaults to ./data/archive
# inside the repo so a fresh `git clone` + `docker compose up` works without
# touching this file. Override only if the archive lives somewhere else.
#
# Examples:
#   ARCHIVE_PATH=./data/archive      # default — repo-relative, cross-platform
#   ARCHIVE_PATH=D:/fair-data        # Windows absolute
#   ARCHIVE_PATH=/mnt/datasets/cga   # Linux absolute / NAS mount
ARCHIVE_PATH=./data/archive

# ─── PostgreSQL + PostGIS ─────────────────────────────────────
# Service name 'postgres' resolves inside Docker network
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=fair_constitution
DB_USERNAME=fc_user
DB_PASSWORD=fc_password

# ─── Redis ───────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─── Cache / Queue / Session ─────────────────────────────────
BROADCAST_DRIVER=log
# Laravel 12 reads CACHE_STORE (not CACHE_DRIVER). Both are kept for
# back-compat with older code paths but Laravel only honors CACHE_STORE.
# Redis is required for tagged caches (revealed.geojson invalidation
# in LegislatureController). Falling back to `database` here breaks
# every Cache::tags(...) call.
CACHE_DRIVER=redis
CACHE_STORE=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# ─── Mail (dev — use log driver so emails go to logs) ────────
MAIL_MAILER=log
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@fair-constitution.local"
MAIL_FROM_NAME="${APP_NAME}"

# ─── Vite ────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
