APP_NAME="Fair Constitution"
APP_ENV=local
# Pre-baked dev key so a fresh `cp .env.example .env && docker compose up -d`
# works without a separate `php artisan key:generate` step. This key is for
# local development only — production deployments MUST regenerate via
# `php artisan key:generate --force` before going public, otherwise sessions
# and signed URLs are forgeable by anyone with a copy of the repo.
APP_KEY=base64:OtMjb7L/Qa9gR8mlUH7yweAD+rokqP/z5FFA9cbl7hU=
APP_DEBUG=true
APP_URL=http://localhost:8080

# ─── Docker multi-stack config ───────────────────────────────
# These four variables let multiple checkouts (parent + N worktrees) run
# their docker stacks simultaneously without colliding on container names
# or host ports. Defaults below match the parent's canonical setup; copy
# this file to .env in each worktree and bump the values.
#
# Worktree example (run alongside the parent):
#   CONTAINER_PREFIX=fcw
#   NGINX_HOST_PORT=8081
#   POSTGRES_HOST_PORT=5433
#   VITE_HOST_PORT=5174
# CONTAINER_PREFIX=fc
# NGINX_HOST_PORT=8080
# POSTGRES_HOST_PORT=5432
# VITE_HOST_PORT=5173

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Geospatial archive path ─────────────────────────────────
# Where the geoBoundaries + WorldPop archive lives on the host. Bind-mounted
# into the etl container at /archive (read-only). Defaults to ./data/archive
# inside the repo so a fresh `git clone` + `docker compose up` works without
# touching this file. Override only if the archive lives somewhere else.
#
# Examples:
#   ARCHIVE_PATH=./data/archive      # default — repo-relative, cross-platform
#   ARCHIVE_PATH=D:/fair-data        # Windows absolute
#   ARCHIVE_PATH=/mnt/datasets/cga   # Linux absolute / NAS mount
ARCHIVE_PATH=./data/archive

# ─── Protomaps PMTiles basemap directory ─────────────────────
# Host directory holding the dated YYYYMMDD.pmtiles vector-basemap bundle,
# bind-mounted read-only into app + nginx at /maps/protomaps. Defaults to a
# repo-relative path so a fresh `git clone` + `docker compose up` parses and
# starts on ANY OS (a Windows-absolute default broke compose volume parsing on
# Linux). An empty/missing dir just means no vector basemap — fine for a
# federation mirror or a fresh box; override to serve real tiles.
#
# Examples:
#   PROTOMAPS_DIR=./data/protomaps                                   # default — cross-platform
#   PROTOMAPS_DIR=D:/fair-constitution-map-files/protomaps_pmtiles   # Windows absolute
#   PROTOMAPS_DIR=/mnt/datasets/protomaps                            # Linux absolute / NAS mount
PROTOMAPS_DIR=./data/protomaps

# ─── PostGIS image (architecture) ────────────────────────────
# The official postgis/postgis:17-3.5 image is amd64-only. On arm64 hosts
# (Raspberry Pi, ARM servers, Apple Silicon) the stack won't pull/`up` — set
# the multi-arch rebuild instead (same Postgres 17 + PostGIS 3.5, data-compatible):
#   POSTGIS_IMAGE=imresamu/postgis:17-3.5    # arm64 (and amd64)
# POSTGIS_IMAGE=postgis/postgis:17-3.5       # default (amd64)

# ─── Federation self-URL (multibox / mesh) ───────────────────
# The externally-reachable base URL THIS box advertises to peers at handshake, so they can
# reach it back (a joiner discovers it; a host pushes live writes to a joined mirror). REQUIRED
# for a multibox run on two separate machines — leave it unset for a solo box.
#   • A host (Box A) advertises accepting_joins=true ONLY when this is non-empty — unset ⇒ a
#     discovering node sees it as "not open".
#   • A joiner (Box B) advertises this so the host can push live replication back to it (Gate 3).
# Use each box's LAN-reachable base URL. `host.docker.internal` only works when both boxes are on
# ONE host — it is NOT reachable from another machine on the LAN.
#   FEDERATION_SELF_URL=http://192.168.1.202:8081   # example host
#   FEDERATION_SELF_URL=http://192.168.1.203:8080   # example joiner
# See docs/operator/multibox-ui-run.md (step 0).
# FEDERATION_SELF_URL=

# ─── Matrix homeserver (Phase K-3 — the live commons, Plane B) ───
# ONE CGA instance = ONE Matrix homeserver, federating peer-to-peer like the
# federation_peers mesh. Synapse is the dev default (feature-complete; matrix-org/synapse
# was archived Apr 2024 → maintained image lives at element-hq, AGPLv3). MATRIX_IMPL is the
# human choice; deploy.sh resolves it to MATRIX_IMAGE by arch (Dendrite is the Pi candidate,
# pending the rig spike). Set MATRIX_DOMAIN to your server_name for a real deployment.
MATRIX_IMPL=synapse
# MATRIX_IMAGE=ghcr.io/element-hq/synapse:latest   # resolved by deploy.sh; override to pin a tag
MATRIX_DOMAIN=localhost
MATRIX_HOST_PORT=8008
# MAS (Matrix Authentication Service) — Synapse delegates auth here (MSC3861/OIDC); the homeserver
# never sees a password. ISSUER is the public URL clients reach (host port); MATRIX_MAS_URL is the
# internal Docker URL Synapse uses. A real deploy regenerates the MAS config + secret via matrix:setup.
MAS_HOST_PORT=8090
MATRIX_MAS_ISSUER=http://localhost:8090/
# MATRIX_MAS_URL=http://mas:8080/
# MAS_IMAGE=ghcr.io/element-hq/matrix-authentication-service:latest   # resolved by deploy.sh
# Appservice + MAS tokens are minted by `php artisan matrix:setup` (K3-D); leave blank here.
# MATRIX_AS_TOKEN=
# MATRIX_HS_TOKEN=
# MATRIX_ADMIN_TOKEN=
# LiveKit (voice/video, K3-J) — dev-stack only; Pi A/V deferred to scaling boxes.
# LIVEKIT_API_KEY=devkey
# LIVEKIT_API_SECRET=secret

# ─── PostgreSQL + PostGIS ─────────────────────────────────────
# Service name 'postgres' resolves inside Docker network
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=fair_constitution
DB_USERNAME=fc_user
DB_PASSWORD=fc_password

# ─── Redis ───────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─── Cache / Queue / Session ─────────────────────────────────
BROADCAST_DRIVER=log
# Laravel 12 reads CACHE_STORE (not CACHE_DRIVER). Both are kept for
# back-compat with older code paths but Laravel only honors CACHE_STORE.
# Redis is required for tagged caches (revealed.geojson invalidation
# in LegislatureController). Falling back to `database` here breaks
# every Cache::tags(...) call.
CACHE_DRIVER=redis
CACHE_STORE=redis
# The `database` cache store backstops the federation/mesh throttle:N,1 limiter
# whenever CACHE_STORE ever resolves to `database`. Pin its connection to pgsql so
# it can NEVER fall through to the sqlite default and 500 every /api/federation
# route on a fresh clone (config/database.php defaults to pgsql for the same reason).
DB_CACHE_CONNECTION=pgsql
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
# How long a reserved job on the LONG lane (long-running / autoscale /
# prewarm supervisors) may run before redelivery. Sweeps run for hours — the
# Laravel default (90s) would ghost-redeliver them mid-run. The default
# queue keeps the 90s (REDIS_QUEUE_RETRY_AFTER) so short jobs recover fast.
REDIS_QUEUE_LONG_RETRY_AFTER=14400

# Autoscale width: UNSET (default) = the governor decides — it probes the
# host each tick and walks the busy-width to the real knee (up on headroom,
# down on saturation/failures, halved on a postgres restart), bounded only
# by core count. Setting a number PINS the width and disables the governor.
# CGA_AUTOSCALE_WORKERS=
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# ─── Mail (dev — use log driver so emails go to logs) ────────
MAIL_MAILER=log
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@fair-constitution.local"
MAIL_FROM_NAME="${APP_NAME}"

# ─── Vite ────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
