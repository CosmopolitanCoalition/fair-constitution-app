# ─── ETL source data — too large for git ──────────────────────────────────────
# See docs/DATA_ACQUISITION.md for how to acquire these locally.
docs/worldpop_100m_latest/
docs/geoBoundaries_repo/

# ─── ETL runtime artifacts ────────────────────────────────────────────────────
scripts/etl/progress.json
scripts/etl/*.log
scripts/etl/__pycache__/
# Supervisor + heartbeat control files (bars.json, current.json, running.json,
# failed.json, halt.json, paused_on_error.json, error_resolution.json,
# caches_warmed.json, raster_prewarm_dispatched.json, t7_dryrun*) — all
# runtime state written by the live ETL, not source. The directory itself
# is created by error_pause.py / heartbeat.py at first write.
scripts/etl/control/

# ─── Python ───────────────────────────────────────────────────────────────────
**/__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# ─── Windows ──────────────────────────────────────────────────────────────────
desktop.ini
Thumbs.db
*.ini

# ─── Protomaps PMTiles bundle (P.7) ───────────────────────────────────────────
# ~150 MB self-hostable base map; fetched via scripts/setup/fetch_protomaps.sh
# at install time, never committed.
public/maps/*.pmtiles

# Phase K-3 — scratch output of `mas-cli config generate` (the committed dev config is config.yaml,
# carrying DEV-ONLY secrets like the repo's dev APP_KEY; deploy.sh / matrix:setup regenerate for prod)
docker/matrix/mas/config.generated.yaml
